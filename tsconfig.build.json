{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "module": "CommonJS",
    "moduleResolution": "Node"
  },
  "include": [
    "src/index.ts",
    "src/cron-expression.ts",
    "src/cron-builder.ts",
    "src/interfaces/scheduler.interface.ts",
    "src/errors/duplicate-job.error.ts",
    "src/decorators/scheduler.decorators.ts",
    "src/services/scheduler.service.ts",
    "src/scheduler.module.ts"
  ],
  "exclude": ["dist", "node_modules", "**/*.spec.ts", "**/*.test.ts"]
}
